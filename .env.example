# Copy to `.env.local`. Optional: defaults also exist in lib/static-api-defaults.ts

NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Same secret as backend APP_TOKEN (or use NEXT_PUBLIC_API_KEY).
NEXT_PUBLIC_APP_TOKEN=choose-one-long-random-string

# Password reset links are built on the server (FRONTEND_PASSWORD_RESET_BASE_URL) and sent by SMTP when configured.
