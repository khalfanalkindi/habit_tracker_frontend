# Copy to `.env.local` for API integration (optional — without these, demo login + local profile only).

# Backend base URL (no trailing slash), e.g. http://127.0.0.1:8000
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Same value as backend API_STATIC_KEY (when set). Sent as X-API-Key on every request.
NEXT_PUBLIC_API_KEY=your-static-api-key
